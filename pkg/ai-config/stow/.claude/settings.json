{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "agentPushNotifEnabled": true,
  "effortLevel": "high",
  "enabledPlugins": {
    "claude-code-setup@claude-plugins-official": true
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "${HOME}/.claude/notification.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "[ -f \"${HOME}/.claude/CLAUDE-work.md\" ] && cat \"${HOME}/.claude/CLAUDE-work.md\" || true",
            "type": "command"
          }
        ],
        "matcher": "startup"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(awk:*)",
      "Bash(brew info:*)",
      "Bash(brew list:*)",
      "Bash(brew search:*)",
      "Bash(cargo:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(cut:*)",
      "Bash(date:*)",
      "Bash(dig:*)",
      "Bash(docker images:*)",
      "Bash(docker logs:*)",
      "Bash(docker ps:*)",
      "Bash(fd:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run view:*)",
      "Bash(host:*)",
      "Bash(jq:*)",
      "Bash(just:*)",
      "Bash(ln:*)",
      "Bash(make:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(npm:*)",
      "Bash(open:*)",
      "Bash(pip:*)",
      "Bash(pnpm:*)",
      "Bash(printenv *)",
      "Bash(pwd)",
      "Bash(pytest:*)",
      "Bash(rg:*)",
      "Bash(ripgrep:*)",
      "Bash(ruff:*)",
      "Bash(sort:*)",
      "Bash(touch:*)",
      "Bash(tr:*)",
      "Bash(tree:*)",
      "Bash(uname:*)",
      "Bash(uniq:*)",
      "Bash(uv:*)",
      "Bash(which:*)",
      "Bash(whoami)",
      "Bash(yarn:*)",
      "Bash(yq:*)",
      "Read(//tmp/**)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:dev.to)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:doc.rust-lang.org)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:news.ycombinator.com)",
      "WebFetch(domain:nodejs.org)",
      "WebFetch(domain:pkg.go.dev)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:skills.sh)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:www.npmjs.com)",
      "WebSearch"
    ],
    "ask": [
      "Skill(update-config)",
      "Bash(brew install:*)",
      "Bash(brew uninstall:*)"
    ],
    "deny": [
      "Bash(env)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(gh api:*)",
      "Bash(fd * -x *)",
      "Bash(fd * --exec *)",
      "Bash(fd * -X *)",
      "Bash(fd * --exec-batch *)",
      "Bash(fd * -uu*)",
      "Bash(fd * --no-ignore*)",
      "Bash(fd * -H*)",
      "Bash(fd * --hidden*)",
      "Bash(fd * ~*)",
      "Bash(fd * /*)",
      "Bash(printenv)",
      "Bash(printenv * | *)",
      "Bash(printenv *TOKEN*)",
      "Bash(printenv *KEY*)",
      "Bash(printenv *ID*)",
      "Bash(printenv *DATABASE_URL*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(~/.aws/credentials)",
      "Read(~/.ssh/**)"
    ]
  },
  "statusLine": {
    "command": "~/.local/bin/starship-claude",
    "padding": 0,
    "type": "command"
  },
  "voiceEnabled": true
}