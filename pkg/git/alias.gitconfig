### config ###
cf = "config"

### describe ###

### diff ###
d = "diff"

### fetch ###
f = "fetch"

### grep ###

### gui ###
#! Not very useful

### log ###
#! Favor GUI and AI tool
# ┌─────────────────┬──────────────────────────────────────────────────────┐
# │      flag       │                     what it does                     │
# ├─────────────────┼──────────────────────────────────────────────────────┤
# │ --oneline       │ one line per commit (short hash + subject)           │
# ├─────────────────┼──────────────────────────────────────────────────────┤
# │ --stat          │ adds files-changed summary below each commit         │
# ├─────────────────┼──────────────────────────────────────────────────────┤
# │ --name-only     │ lists changed file paths only, no stats              │
# ├─────────────────┼──────────────────────────────────────────────────────┤
# │ --patch / -p    │ adds full diff below each commit                     │
# ├─────────────────┼──────────────────────────────────────────────────────┤
# │ --pretty=...    │ custom colored format (replaces default)             │
# ├─────────────────┼──────────────────────────────────────────────────────┤
# │ --graph         │ ASCII branch graph on the left                       │
# ├─────────────────┼──────────────────────────────────────────────────────┤
# │ --decorate      │ shows branch/tag labels next to commits              │
# ├─────────────────┼──────────────────────────────────────────────────────┤
# │ --all           │ includes all branches and tags                       │
# ├─────────────────┼──────────────────────────────────────────────────────┤
# │ --no-merges     │ hides merge commits                                  │
# ├─────────────────┼──────────────────────────────────────────────────────┤
# │ --follow        │ tracks renames across a single file's history        │
# ├─────────────────┼──────────────────────────────────────────────────────┤
# │ --author=...    │ filters commits by author name/email                 │
# ├─────────────────┼──────────────────────────────────────────────────────┤
# │ --grep=...      │ filters commits by message text                      │
# ├─────────────────┼──────────────────────────────────────────────────────┤
# │ --since/--until │ filters by date range (e.g. --since="2 weeks ago")   │
# ├─────────────────┼──────────────────────────────────────────────────────┤
# │ -n <N>          │ limit output to N most recent commits                │
# └─────────────────┴──────────────────────────────────────────────────────┘

### ls-files ###
# ls = "ls-files --exclude-standard"
# ls-new = "ls-files --others --exclude-standard"                 # Untracked
# ls-untracked = "ls-files --others --exclude-standard"           # New
# ls-modified = "ls-files --modified --exclude-standard"          # Tracked and modified
# ls-stagable = "ls-files --modified --others --exclude-standard" # Untracked + modified
# ls-ignored = "ls-files --ignored --others --exclude-standard"   # Ignored by .gitignore

### merge ###
m = "merge"

### pull ###
p = "pull"

### push ###
ps = "push"
ps-f = "push --force-with-lease"
ps-ff = "push --force"

### rebase ###
rb-m = !"git rebase $(main-branch)" # Rebase with main/master branch
rb-i = "rebase --interactive"

### remote ###

### reset ###

### revert ###

### rm ###
#! Favor delete-and-add

### show ###

### stash ###
s = "stash"
s-l = "stash list"
s-u = "stash --include-untracked"
s-a = "stash apply"
s-p = "stash pop"
# Stash-revert: generates the inverse diff of current working changes into a new stash entry.
# 1. commit so revert has a target
# 2. generate the inverse
# 3. stash the inverse
# 4. nuke the temp commit
# 5. restore original changes
s-revert = !"f() { \
  git add -A && \
  git commit -m 'temp' && \
  git revert HEAD --no-commit && \
  git stash push -m 'revert' && \
  git reset --hard HEAD~1 && \
  git stash pop stash@{1}; \
}; f"

