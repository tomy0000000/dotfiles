[alias]

###############################################################################
# Apps                                                                        #
###############################################################################

tower = !"gittower ."

###############################################################################
# Snippets                                                                    #
###############################################################################

# Get the git repository root path
root = "rev-parse --show-toplevel"

# Give up changes made
discard = "checkout --"

# Put staged back to unstaged
unadd = "reset HEAD"
unstage = "reset HEAD"

# Tear down the most recent commit and keep changes
uncommit = "reset --soft HEAD~1"

# Touch the last commit to update the timestamp
# but not changing the commit
touch = !"git commit --amend --no-edit --date=\"$(date '+%s %z')\""

# Get the main branch name
# https://stackoverflow.com/a/67672350/10325430
main-branch = !"git symbolic-ref refs/remotes/origin/HEAD | cut -d'/' -f4"

# Generate .gitignore file
# https://docs.gitignore.io/install/command-line
gen-ignore = "!gi() { curl -sL https://www.toptal.com/developers/gitignore/api/$@ ;}; gi"

# Assume/unassume unchanged files
ignore="update-index --assume-unchanged"
unignore="update-index --no-assume-unchanged"
ignored="ls-files -v | grep '^[[:lower:]]'"

# Prune everything that is unreachable
pruner = !"git prune --expire=now; git reflog expire --expire-unreachable=now --rewrite --all"

# Repack a repo the way Linus recommends
# It does the equivalent of `git gc --aggressive` but done *properly*
repacker = "repack -a -d -f --depth=300 --window=300 --window-memory=1g"

# clean everything to be pristine
cleanest = "clean -ffdx"

# Recent 5 commits
log-recent = "!git --no-pager log -5 --name-only --pretty=format:'%Cgreen%ad %Cred%h%Creset -%C(yellow)%d%Creset %s %Cblue[%cn]%Creset' --date=human"

# Topo Graph
log-graph = "log --graph --topo-order --date=short --abbrev-commit --decorate --all --boundary --pretty=format:'%Cgreen%ad %Cred%h%Creset -%C(yellow)%d%Creset %s %Cblue[%cn]%Creset %Cblue%G?%Creset'"

# One-liner pager
log-awesome = "log --oneline --date-order --date=short --abbrev-commit --decorate --all --boundary --pretty=format:'%Cgreen%ad %Cred%h%Creset -%C(yellow)%d%Creset %s %Cblue[%cn]%Creset %Cblue%G?%Creset'"

###############################################################################
# Commands                                                                    #
###############################################################################

